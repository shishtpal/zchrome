{
  "version": 2,
  "commands": [
    {
      "action": "load",
      "file": "automations/youtube/data/yt-users.json",
      "as": "users"
    },
    {
      "action": "foreach",
      "source": "$users",
      "as": "user",
      "file": "subscribe-single.json",
      "on_error": "continue"
    }
  ]
}
