{
  "version": 2,
  "commands": [
    {
      "action": "navigate",
      "value": "https://www.bing.com/"
    },
    {
      "action": "fill",
      "selector": "#sb_form_q",
      "selectors": [
        "#sb_form_q",
        "textarea[name=\"q\"]",
        "textarea[aria-label=\"Enter your search here - Search suggestions will show as you type\"]",
        ".sb_form_q",
        ".sb_form_ic > textarea:nth-of-type(1)"
      ],
      "value": "edfiller"
    },
    { "action": "press", "key": "Enter" },
    {
      "action": "assert",
      "selector": ".b_vtl_deeplinks > h2:nth-of-type(1) > a:nth-of-type(1)"
    },
    {
      "action": "click",
      "selector": ".b_LinksColorMD",
      "selectors": [
        ".b_LinksColorMD",
        ".b_vtl_deeplinks > h2:nth-of-type(1) > a:nth-of-type(1)"
      ]
    }
  ]
}
